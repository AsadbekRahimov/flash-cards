# LexiFlow Pro — Dev image.
# Полный образ для локальной разработки: PHP 8.3, Xdebug, Node 20 (для Vite),
# composer, git, bash, oh-my-quality-of-life tools. НЕ использовать в проде.
FROM php:8.3-fpm-alpine

ARG UID=1000
ARG GID=1000

ENV COMPOSER_ALLOW_SUPERUSER=1 \
    COMPOSER_MEMORY_LIMIT=-1 \
    PHP_IDE_CONFIG="serverName=lexiflow"

RUN apk add --no-cache \
        bash git curl icu-dev oniguruma-dev libzip-dev libpng-dev \
        postgresql-dev linux-headers autoconf g++ make \
        nodejs npm shadow su-exec less vim \
    && docker-php-ext-install -j"$(nproc)" \
        pdo pdo_pgsql bcmath intl mbstring opcache pcntl zip \
    && pecl install redis xdebug \
    && docker-php-ext-enable redis xdebug \
    && apk del autoconf g++ make linux-headers \
    && rm -rf /tmp/* /var/cache/apk/*

COPY --from=composer:2 /usr/bin/composer /usr/bin/composer

# Xdebug — выключен по умолчанию, включается через XDEBUG_MODE env var
# (например, XDEBUG_MODE=debug или XDEBUG_MODE=coverage).
RUN { \
        echo "xdebug.mode=\${XDEBUG_MODE:-off}"; \
        echo "xdebug.start_with_request=yes"; \
        echo "xdebug.client_host=host.docker.internal"; \
        echo "xdebug.client_port=9003"; \
        echo "xdebug.idekey=PHPSTORM"; \
        echo "xdebug.discover_client_host=0"; \
        echo "xdebug.log_level=0"; \
    } > /usr/local/etc/php/conf.d/xdebug.ini

# Дев-настройки PHP: больше памяти, длиннее таймауты, показывать ошибки.
RUN { \
        echo "memory_limit=512M"; \
        echo "upload_max_filesize=64M"; \
        echo "post_max_size=64M"; \
        echo "max_execution_time=300"; \
        echo "display_errors=On"; \
        echo "display_startup_errors=On"; \
        echo "error_reporting=E_ALL"; \
        echo "opcache.enable=1"; \
        echo "opcache.validate_timestamps=1"; \
        echo "opcache.revalidate_freq=0"; \
    } > /usr/local/etc/php/conf.d/zz-dev.ini

# Создаём пользователя app с UID/GID хоста, чтобы файлы из контейнера
# не оказывались под root на macOS/Linux. На Windows (named volume) UID
# не критичен, но поведение остаётся одинаковым.
RUN if getent group ${GID} >/dev/null 2>&1; then \
        groupmod -n app "$(getent group ${GID} | cut -d: -f1)"; \
    else \
        addgroup -g ${GID} app; \
    fi \
    && if getent passwd ${UID} >/dev/null 2>&1; then \
        usermod -l app -d /home/app -m -g app "$(getent passwd ${UID} | cut -d: -f1)"; \
    else \
        adduser -D -u ${UID} -G app -s /bin/bash app; \
    fi \
    && mkdir -p /home/app/.composer /home/app/.npm \
    && chown -R app:app /home/app

WORKDIR /var/www/html

USER app

CMD ["php-fpm"]
