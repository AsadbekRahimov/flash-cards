APP_NAME=LexiFlow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=80

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=lexiflow
DB_USERNAME=lexiflow
DB_PASSWORD=secret
DB_PORT_HOST=5432

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_SAME_SITE=lax

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PORT_HOST=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@lexiflow.local"
MAIL_FROM_NAME="${APP_NAME}"

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_URL_SECRET=
TELEGRAM_HEADER_SECRET=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_QUEUE=high
TELEGRAM_IP_ALLOWLIST_ENABLED=false

TWA_JWT_SECRET=
TWA_JWT_TTL=900
TWA_JWT_ALG=HS256
TWA_JWT_ISS=lexiflow
TWA_INIT_DATA_MAX_AGE=86400
TWA_MAX_CARDS_PER_SESSION=100
TWA_BASE_URL=

TTS_SERVICE_URL=http://tts:8000

SENTRY_LARAVEL_DSN=

# spatie/laravel-backup
# Comma-separated disk names (see config/filesystems.php). Default: local.
# For offsite backups add 's3' and configure AWS_* vars below.
BACKUP_DISKS=local
BACKUP_NOTIFICATION_MAIL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

UID=1000
GID=1000

VITE_APP_NAME="${APP_NAME}"
VITE_PORT_HOST=5173

# Xdebug — off|debug|develop|coverage|profile (см. https://xdebug.org/docs/all_settings#mode)
XDEBUG_MODE=off

# ngrok (для локальной разработки Telegram webhook).
# Токен: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
NGROK_WEB_PORT=4040
