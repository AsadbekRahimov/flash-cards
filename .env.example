APP_NAME=LexiFlow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_PORT=80

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=lexiflow
DB_USERNAME=lexiflow
DB_PASSWORD=secret
DB_PORT_HOST=5432

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PORT_HOST=6379

MAIL_MAILER=log
MAIL_FROM_ADDRESS="hello@lexiflow.local"
MAIL_FROM_NAME="${APP_NAME}"

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_URL_SECRET=
TELEGRAM_HEADER_SECRET=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_QUEUE=high

TWA_JWT_SECRET=
TWA_JWT_TTL=3600

TTS_SERVICE_URL=http://tts:8000

SENTRY_LARAVEL_DSN=

UID=1000
GID=1000

VITE_APP_NAME="${APP_NAME}"
