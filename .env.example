APP_NAME=LexiFlow
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
# Used by docker-compose.prod.yml and nginx certificate paths.
APP_DOMAIN=localhost
APP_PORT=80
APP_PREVIOUS_KEYS=

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=redis

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_DEPRECATIONS_TRACE=false
LOG_LEVEL=debug
LOG_DAILY_DAYS=14

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=lexiflow
DB_USERNAME=lexiflow
DB_PASSWORD=secret
DB_PORT_HOST=5432
DB_SSLMODE=prefer

SESSION_DRIVER=redis
SESSION_CONNECTION=session
SESSION_STORE=redis
SESSION_LIFETIME=120
SESSION_EXPIRE_ON_CLOSE=false
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=null
SESSION_SECURE_COOKIE=true
SESSION_HTTP_ONLY=true
SESSION_SAME_SITE=lax
SESSION_PARTITIONED_COOKIE=false

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
QUEUE_FAILED_DRIVER=database-uuids

CACHE_STORE=redis
CACHE_PREFIX=lexiflow_cache

REDIS_CLIENT=phpredis
REDIS_HOST=redis
REDIS_USERNAME=null
REDIS_PASSWORD=null
REDIS_PORT=6379
REDIS_PORT_HOST=6379
REDIS_DB=0
REDIS_CACHE_CONNECTION=cache
REDIS_CACHE_DB=1
REDIS_CACHE_LOCK_CONNECTION=locks
REDIS_QUEUE_CONNECTION=queue
REDIS_QUEUE_DB=2
REDIS_SESSION_DB=3
REDIS_LOCK_DB=4
REDIS_QUEUE=default
REDIS_QUEUE_RETRY_AFTER=90
REDIS_QUEUE_BLOCK_FOR=5
REDIS_MAX_RETRIES=3
REDIS_BACKOFF_ALGORITHM=decorrelated_jitter
REDIS_BACKOFF_BASE=100
REDIS_BACKOFF_CAP=1000
REDIS_MAXMEMORY=256mb
REDIS_MAXMEMORY_POLICY=noeviction

MAIL_MAILER=log
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@lexiflow.local"
MAIL_FROM_NAME="${APP_NAME}"

TELEGRAM_BOT_TOKEN=
TELEGRAM_BOT_USERNAME=
TELEGRAM_URL_SECRET=
TELEGRAM_HEADER_SECRET=
TELEGRAM_WEBHOOK_URL=
TELEGRAM_QUEUE=high
TELEGRAM_IP_ALLOWLIST_ENABLED=false
TELEGRAM_LOG_CHANNEL=telegram

TWA_JWT_SECRET=
TWA_JWT_TTL=900
TWA_JWT_ALG=HS256
TWA_JWT_ISS=lexiflow
TWA_INIT_DATA_MAX_AGE=86400
TWA_MAX_CARDS_PER_SESSION=100
TWA_BASE_URL=

TTS_SERVICE_URL=http://tts:8000
TTS_SERVICE_TIMEOUT=8

SENTRY_LARAVEL_DSN=

# spatie/laravel-backup
# Comma-separated disk names (see config/filesystems.php). Default: local.
# For offsite backups add 's3' and configure AWS_* vars below.
BACKUP_DISKS=local
BACKUP_ARCHIVE_PASSWORD=
BACKUP_NOTIFICATION_MAIL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_BUCKET=
AWS_URL=
AWS_ENDPOINT=
AWS_USE_PATH_STYLE_ENDPOINT=false

UID=1000
GID=1000

VITE_APP_NAME="${APP_NAME}"
VITE_PORT_HOST=5173

# Xdebug — off|debug|develop|coverage|profile (см. https://xdebug.org/docs/all_settings#mode)
XDEBUG_MODE=off

# ngrok (для локальной разработки Telegram webhook).
# Токен: https://dashboard.ngrok.com/get-started/your-authtoken
NGROK_AUTHTOKEN=
NGROK_WEB_PORT=4040
